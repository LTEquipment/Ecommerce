# Normalize line endings to LF on checkin.
* text=auto eol=lf

# Treat binary assets as binary (no diffs / EOL conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary

# Collapse the lockfile in diffs / reviews.
package-lock.json -diff linguist-generated
