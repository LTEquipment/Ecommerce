# Supabase (fill in when you wire the backend — see lib/supabase/README.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, never expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (optional — leave blank to keep the demo checkout).
# When set, the payment scaffolds in app/api/checkout/session + app/api/webhooks/stripe
# activate. NEXT_PUBLIC_ is browser-safe; the others are server-only secrets.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Affirm — Buy Now, Pay Later (optional). Activates app/api/checkout/affirm.
# NEXT_PUBLIC_ loads Affirm.js in the browser; the others are server-only.
NEXT_PUBLIC_AFFIRM_PUBLIC_KEY=
AFFIRM_PUBLIC_KEY=
AFFIRM_PRIVATE_KEY=
AFFIRM_ENV=sandbox

# --- ERP order sync (optional) ---
# Mirrors placed orders into the ERP as sales_orders. Both must be set or the
# push is skipped entirely, so the storefront runs unchanged without them.
# URL: https://<erp-project>.supabase.co/functions/v1/ingest-storefront-order
# TOKEN: must equal STOREFRONT_INGEST_TOKEN in the ERP project's function secrets.
# This is NOT the ERP service-role key — the storefront must never hold that.
ERP_INGEST_URL=
ERP_INGEST_TOKEN=
# Catalog feed: pulls ERP price + stock onto products the storefront already
# sells. Updates only, never creates. Uses the same token as order ingest.
# URL: https://<erp-project>.supabase.co/functions/v1/export-catalog
ERP_CATALOG_URL=
